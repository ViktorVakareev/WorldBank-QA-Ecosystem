{
  "Framework": {
    "TargetEnvironment": "local",
    "BaseUrl": "http://sandbox.worldbank.internal",
    "MockApiUrl": "http://localhost:5050"
  },

  "Playwright": {
    "Headless": false, // See the browser locally! (Overrides CI 'true')
    "SlowMoMilliseconds": 500, // Slows down execution so the human eye can watch the UI
    "RecordVideo": "on", // Always record locally (CI might be "retain-on-failure")
    "ViewportWidth": 1920,
    "ViewportHeight": 1080
  },

  "Timeouts": {
    "LocatorTimeoutMs": 15000, // How long Playwright waits for an element
    "NavigationTimeoutMs": 30000, // How long to wait for a page load
    "GlobalTestTimeoutMinutes": 5 // Safety net for deadlocks
  },

  "AiTriage": {
    "Enabled": true,
    "ModelName": "llama3",
    "Endpoint": "http://localhost:11434/api/generate",
    "MaxProcessingTimeSeconds": 300 // 5 minutes for local GPU, CI might use 60s
  },

  "TestUsers": {
    "AdminRole": {
      "Username": "admin_local",
      "Password": "Password123!" // Safe to put here because this file is Git-ignored!
    },
    "ReadRole": {
      "Username": "viewer_local",
      "Password": "Password123!"
    }
  }
}